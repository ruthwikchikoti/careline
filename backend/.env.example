# CareLine backend — local config. Copy to `.env` and fill in (never commit .env).
#
# A real LLM is the primary reasoner. Set ONE provider key; the spine prefers
# OpenAI when OPENAI_API_KEY is present, else Anthropic, else the offline twins.

OPENAI_API_KEY=sk-...your-openai-key...

# Optional overrides:
# CARELINE_LLM_MODEL=gpt-5.5        # default for OpenAI; set gpt-4o etc. if needed
# CARELINE_LLM_BACKEND=openai       # force a backend (openai | anthropic | heuristic)
# CARELINE_LLM_EFFORT=high
# ANTHROPIC_API_KEY=sk-ant-...      # alternative provider
